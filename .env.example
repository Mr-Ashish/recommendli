# Storage provider: s3 (AWS) or r2 (Cloudflare). Can be overridden with --storage CLI arg.
STORAGE_PROVIDER=s3

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET=autopostassests
S3_REGION=ap-south-1

# ── Cloudflare R2 (only needed if STORAGE_PROVIDER=r2 or --storage r2) ───────
CF_R2_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET=
# Public URL base for your R2 bucket (custom domain or r2.dev URL)
# e.g. https://pub-xxxxxxxxxxxx.r2.dev  OR  https://assets.yourdomain.com
CF_R2_PUBLIC_URL_BASE=